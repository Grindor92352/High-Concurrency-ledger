# Copy this file to .env and adjust as needed, or export these as real
# environment variables before running the app. Never commit a real .env.

DB_USERNAME=ledger_user
DB_PASSWORD=changeme

# Must be at least 32 bytes for HS256. Generate your own for anything beyond local testing, e.g.:
#   openssl rand -base64 48
JWT_SECRET=CHANGE_ME_32_BYTE_MINIMUM_SECRET_KEY_FOR_HS256
